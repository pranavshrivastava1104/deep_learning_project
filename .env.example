# Application
APP_ENV=development
GIT_SHA=unknown

# Logging (containers override LOG_FORMAT to json and SERVICE_NAME per process)
LOG_LEVEL=INFO
LOG_FORMAT=console
SERVICE_NAME=ml-challenge

# PostgreSQL with pgvector
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_DB=ml_platform
POSTGRES_USER=ml_user
POSTGRES_PASSWORD=change-me

# Redis
REDIS_HOST=redis
REDIS_PORT=6379

# MLflow
MLFLOW_TRACKING_URI=http://mlflow:5000
